# CourseLens — copy to .env and fill in.
#   cp .env.example .env

# Required: free key from https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Optional: set to 0 to hide YouTube ingestion (yt-dlp is blocked from most
# datacenter/cloud IPs, so hosted deploys should disable it).
ENABLE_YOUTUBE=1

# Optional: set to 0 to disable the corrective-RAG grader (used by the eval
# harness ablation; leave on for normal use).
ENABLE_GRADER=1
